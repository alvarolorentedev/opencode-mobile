# Learn more https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files

# dependencies
node_modules/

# Expo
.expo/
dist/
web-build/
expo-env.d.ts

# Native
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem

# local env files
.env*.local

# typescript
*.tsbuildinfo

app-example

# generated native folders
/ios
/android

# Expo / EAS local config
app.json
eas.json
.easignore
credentials.json

# Local environment files
# By default we ignore `.env` (local secrets). If you want to commit a safe
# environment file containing non-secret values (like `EXPO_EAS_PROJECT_ID`),
# add and commit `.env.commit` and remove `.env` from this list.
.env
.env.*
# Allow explicitly committed safe env file
#.env.commit
 
# Local config (may contain tokens/secrets)
config.json
# Google Play / service account JSONs
google-play-service-account.json
service-account*.json
